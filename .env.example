# Solo Founder Agents - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Keys
# ===========================================

# OpenRouter API Key (required)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# GitHub Personal Access Token (required)
# Get yours at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=ghp_...

# GitHub repository (owner/repo format)
GITHUB_REPO=vovkins/solo-founder-agents

# Telegram Bot Token (optional, for Telegram interface)
# Get yours from @BotFather
TELEGRAM_BOT_TOKEN=

# ===========================================
# LLM Models (OpenRouter format)
# ===========================================

# Product Manager
LLM_PM=openai/gpt-4o

# Analyst
LLM_ANALYST=openai/gpt-4o

# Architect
LLM_ARCHITECT=openai/gpt-4o

# Designer
LLM_DESIGNER=openai/gpt-4o

# Developer (Coder) - using Claude for coding
LLM_DEVELOPER=anthropic/claude-sonnet

# Developer (Reviewer) - different model for review
LLM_REVIEWER=openai/gpt-4o

# QA Engineer
LLM_QA=openai/gpt-4o

# Tech Writer
LLM_TECH_WRITER=openai/gpt-4o

# ===========================================
# OpenRouter Settings
# ===========================================

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
